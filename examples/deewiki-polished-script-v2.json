          "run": "dee-wiki --help",
          "expect": { "contains": "Usage:", "regex": null, "exit_code": 0 },
          "timeout_ms": 120000,
          "source_refs": ["ref_help_0001"],
          "manual_step": false,
          "manual_reason": null
        }
      ]
    },
    {
      "id": "scene_02",
      "title": "Search Wikipedia",
      "steps": [
        {
          "id": "step_search",
          "run": "dee-wiki search \"rust programming\" --limit 5 --json",
          "expect": { "contains": "\"ok\":true", "regex": null, "exit_code": 0 },
          "timeout_ms": 120000,
          "source_refs": ["ref_help_0001"],
          "manual_step": false,
          "manual_reason": null
        }
      ]
    },
    {
