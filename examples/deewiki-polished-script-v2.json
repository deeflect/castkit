          "expect": { "contains": "\"extract\"", "regex": null, "exit_code": 0 },
          "timeout_ms": 120000,
          "source_refs": ["ref_help_0001"],
          "manual_step": false,
          "manual_reason": null
        }
      ]
    },
    {
      "id": "scene_04",
